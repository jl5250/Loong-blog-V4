# ===========================================
# ThriveX v4 Blog — Environment Variables
# Copy this file to .env.local and fill in
# ===========================================

# Backend API (Spring Boot on port 9003)
NEXT_PUBLIC_PROJECT_API=http://localhost:9003/api

# Music API (Netease Cloud Music proxy on port 4000)
NEXT_PUBLIC_MUSIC_API=http://localhost:4000

# ISR caching time in seconds (0 = always fresh)
NEXT_PUBLIC_CACHING_TIME=0



